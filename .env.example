# URL du serveur backend (pour le frontend)
# Remplace par l'IP ou le domaine de ton serveur
VITE_API_URL=http://localhost:3001/api

# Pour un accès depuis le réseau local, utilise ton IP locale :
# VITE_API_URL=http://192.168.1.100:3001/api

# Pour un accès depuis internet (avec domaine) :
# VITE_API_URL=https://ton-domaine.com/api
